rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.photoURL is string;
    }
    
    function isValidTestResult(data) {
      return data.keys().hasAll(['uid', 'examType', 'wpm', 'accuracy', 'errors', 'totalChars', 'timeElapsed', 'timestamp']) &&
             data.uid is string &&
             data.examType in ['RRB', 'SSC'] &&
             data.wpm is number &&
             data.accuracy is number &&
             data.errors is number &&
             data.totalChars is number &&
             data.timeElapsed is number;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Test Results
    match /testResults/{resultId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.uid == request.auth.uid) && isValidTestResult(request.resource.data);
      allow update, delete: if false; // Results are immutable
    }
  }
}
